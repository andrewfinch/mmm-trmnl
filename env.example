# Local Development Example #
#############################
# Copy this file to `.env` and fill in real values.
# The CLI will read these automatically; any flag can still override them.

# --- RevivalHub source ---
REVIVALHUB_URL=https://storage.googleapis.com/revival-hub-ab2a8.firebasestorage.app/airtable-uploads/data-import.json
REVIVALHUB_THEATRE="new beverly"
REVIVALHUB_TIMEZONE=America/Los_Angeles
REVIVALHUB_LOOKAHEAD_HOURS=96

# No TRMNL secrets are required for the pull (Webhooks) model.
