{% assign title = data.title | default: "Coming Soon" %}
{% assign poster_url = data.poster_url %}
{% assign ticket_url = data.ticket_url %}

{% case data.show_day %}
  {% when "Mon" %}{% assign day_full = "Monday" %}
  {% when "Tue" %}{% assign day_full = "Tuesday" %}
  {% when "Wed" %}{% assign day_full = "Wednesday" %}
  {% when "Thu" %}{% assign day_full = "Thursday" %}
  {% when "Fri" %}{% assign day_full = "Friday" %}
  {% when "Sat" %}{% assign day_full = "Saturday" %}
  {% when "Sun" %}{% assign day_full = "Sunday" %}
  {% else %}{% assign day_full = data.show_day %}
{% endcase %}

{% comment %} ---- Showtime label ----
Preferred path: epoch fields from the feed. Pure integer comparisons against
TRMNL's render-time clock, so labels are timezone-proof. Exactly one of these
renders, always paired with the time and nothing else:
  - "Tonight" / "Today" / "Tomorrow"
  - weekday name when the show is within a week
  - calendar date ("Jul 8") when it's further out
Fallback path: the legacy preformatted subtitle string. {% endcomment %}
{% if data.showtime_epoch %}
  {% assign now_epoch = trmnl.system.timestamp_utc | plus: 0 %}
  {% assign day_start = data.day_start_epoch | plus: 0 %}
  {% assign day_end = data.day_end_epoch | plus: 0 %}
  {% assign prev_day_start = day_start | minus: 86400 %}
  {% assign week_ahead = day_start | minus: 604800 %}
  {% assign when_time = data.show_time %}
  {% if now_epoch >= day_start and now_epoch < day_end %}
    {% if data.is_evening %}
      {% assign when_label = "Tonight" %}
    {% else %}
      {% assign when_label = "Today" %}
    {% endif %}
  {% elsif now_epoch >= prev_day_start and now_epoch < day_start %}
    {% assign when_label = "Tomorrow" %}
  {% elsif now_epoch >= week_ahead %}
    {% assign when_label = day_full %}
  {% else %}
    {% assign when_label = data.show_date %}
  {% endif %}
{% else %}
  {% assign when_label = data.subtitle | default: "Showtime TBD" %}
  {% assign when_time = "" %}
{% endif %}

{% assign qr_data = ticket_url | url_encode %}
{% assign qr_src = "https://api.qrserver.com/v1/create-qr-code/?size=100x100&amp;margin=2&amp;data=" | append: qr_data %}

{% comment %} The deployed plugin also embeds a custom "Marquee" @font-face
(woff2 data URI) and a .marquee class; kept out of this reference copy for
readability. See the TRMNL markup editor for the byte-exact deployed version. {% endcomment %}

<div class="layout layout--col layout--center-x gap--none">

  {% if poster_url %}
    <img class="image image-dither no-shrink mx--auto h--[91cqh] w--auto" src="{{ poster_url }}" alt="{{ title | escape }}" />
  {% else %}
    <div class="flex flex--center no-shrink bg--black p--8 w--full h--[91cqh]">
      <span class="title title--xxlarge text--white marquee fallback-title" data-clamp="5">{{ title }}</span>
    </div>
  {% endif %}

  <div class="flex flex--row flex--center-x flex--center-y grow w--full gap--large px--4">
    <span class="title title--xxlarge marquee">{{ when_label }}</span>
    {% if when_time != "" %}
      <span class="title title--xxlarge text--gray-20 marquee">{{ when_time }}</span>
    {% endif %}
    {% if ticket_url %}
      <img class="image no-shrink w--[50px] h--[50px]" src="{{ qr_src }}" alt="QR code for tickets" />
    {% endif %}
  </div>

</div>
